{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "Default": "Server=localhost,1433;Database=RetailOms;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "https://localhost:7015",
    "Audience": "retail-oms-client",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 14,
    "_Key_comment": "Set via: dotnet user-secrets set Jwt:Key <32+ chars>. Never put the dev key in source."
  },
  "Auth": {
    "SecureCookies": false,
    "DefaultAdmin": {
      "Email": "admin@retail.local",
      "DisplayName": "Site Administrator",
      "_Password_comment": "Set via: dotnet user-secrets set Auth:DefaultAdmin:Password <12+ chars incl. a digit>. Never commit the password."
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173", "https://localhost:5173" ]
  },
  "Storage": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "ProductImagesContainer": "product-images"
  }
}
