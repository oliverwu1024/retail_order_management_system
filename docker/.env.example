# ─────────────────────────────────────────────────────────────────────────────
#  .env.example — every environment variable the docker-compose stack expects.
#
#  Copy to `.env` (which IS gitignored) and replace placeholders:
#     cp .env.example .env
#
#  The .env file is read automatically by `docker compose up` when it lives
#  next to docker-compose.yml OR when passed explicitly via --env-file.
#  We keep .env at the REPO ROOT so all subprojects (api, web, eventual
#  Functions host) can share the same source of truth.
#
#  WHY EVEN HAVE A FILE FOR DEV SECRETS?
#  -------------------------------------
#  In dev we use `dotnet user-secrets` for the API process running on the
#  host (Story 0.3 / ADR-0010 follow-up). But when the API runs INSIDE a
#  Docker container, there's no user-secrets store — env vars are the
#  config provider that wins. This file enumerates what compose injects.
# ─────────────────────────────────────────────────────────────────────────────

# ─── SQL Server (sqlserver service) ─────────────────────────────────────────
# SA password. Must satisfy SQL Server's complexity rule: 8+ chars, mixed
# case, digit, and a non-alphanumeric. The compose default works out of the
# box; CHANGE IT for any host you don't fully trust.
MSSQL_SA_PASSWORD=YourStrong!Passw0rd

# ─── JWT auth (api service) ─────────────────────────────────────────────────
# Issuer and audience claims embedded in every issued token.
JWT_ISSUER=https://localhost:7015
JWT_AUDIENCE=retail-oms-client

# Signing key — HMAC-SHA256 requires 32+ chars. Generate a fresh one with:
#     openssl rand -base64 48
# In production this comes from Azure Key Vault via DefaultAzureCredential,
# not env vars. Anything you put here is dev-only.
JWT_KEY=dev-only-replace-me-with-32-plus-character-secret-stored-in-user-secrets

# ─── Azurite (azurite service) ──────────────────────────────────────────────
# Azurite's well-known account name + key. These are PUBLIC defaults baked
# into the emulator; they only work against the emulator. Listed here so
# the API service (Phase 4+ blob uploads) can reference the same string.
AZURITE_ACCOUNT_NAME=devstoreaccount1
AZURITE_ACCOUNT_KEY=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==
