# .editorconfig — root config for the Retail OMS repo                                                                                                                                       
# Spec: https://editorconfig.org/
# .NET-specific keys: https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules                                                                                             
                                                                                                                                                                                            
# Stop editors from walking up the tree looking for more configs.                                                                                                                           
# Without this, ~/.editorconfig (your home dir) could silently override repo rules.                                                                                                         
root = true                                                                                                                                                                                 
                
# ============================================================                                                                                                                              
# Defaults for all files
# UTF-8 + LF + trim trailing whitespace = the "boring correct" defaults                                                                                                                     
# that prevent the most common cross-platform diffs.                                                                                                                                        
# ============================================================                                                                                                                              
[*]                                                                                                                                                                                         
charset                  = utf-8                                                                                                                                                            
end_of_line              = lf            # LF on all platforms. Git's autocrlf is a workaround; this is the fix.
insert_final_newline     = true          # POSIX requires it; many tools (cat, grep, diff) misbehave without.                                                                               
trim_trailing_whitespace = true                                                                                                                                                             
indent_style             = space         # Spaces > tabs for cross-tool consistency. Religious war — pick one and stop arguing.                                                             
indent_size              = 4             # Default; overridden per language below.                                                                                                          
                                                                                                                                                                                            
# ============================================================                                                                                                                              
# C# (.cs) — ASP.NET 10 backend                                                                                                                                                              
# 4-space indent is the .NET community convention (Microsoft docs, dotnet/runtime repo).                                                                                                    
# ============================================================                                                                                                                              
[*.cs]                                                                                                                                                                                      
indent_size                                        = 4                                                                                                                                      
                                                                                                                                                                                            
# --- Language style ---
csharp_new_line_before_open_brace                  = all       # Allman braces — .NET standard.                                                                                             
csharp_new_line_before_else                        = true                                                                                                                                   
csharp_new_line_before_catch                       = true                                                                                                                                   
csharp_new_line_before_finally                     = true                                                                                                                                   
csharp_prefer_braces                               = true:warning   # Always use braces, even on 1-line ifs. Prevents the Apple goto fail; bug class.                                       
                                                                                                                                                                                            
# --- 'var' usage ---
csharp_style_var_for_built_in_types                = false:suggestion   # `int x = 1;` not `var x = 1;` — explicit primitive types read clearer.                                            
csharp_style_var_when_type_is_apparent             = true:suggestion    # `var customer = new Customer();` — type is obvious from RHS.                                                      
csharp_style_var_elsewhere                         = false:suggestion                                                                                                                       
                                                                                                                                                                                            
# --- Modern C# features ---                                                                                                                                                                
csharp_style_expression_bodied_methods             = when_on_single_line:suggestion
csharp_style_expression_bodied_properties          = true:suggestion                                                                                                                        
csharp_style_pattern_matching_over_is_with_cast    = true:warning                                                                                                                           
csharp_style_pattern_matching_over_as_with_null_check = true:warning                                                                                                                        
                                                                                                                                                                                            
# --- using directives ---                                                                                                                                                                  
csharp_using_directive_placement                   = outside_namespace:warning   # `using` outside `namespace` — .NET standard, easier tooling.
dotnet_sort_system_directives_first                = true                        # System.* first, then alphabetical.                                                                       
                                                                                                                                                                                            
# --- Naming conventions ---                                                                                                                                                                
# Private fields: _camelCase. Constants: PascalCase. Interfaces: IPascalCase.                                                                                                               
# (The full naming-rule syntax is verbose; this is the minimal Microsoft-recommended set.)                                                                                                  
dotnet_naming_rule.private_fields_should_be_camel_case_with_underscore.severity = warning                                                                                                   
dotnet_naming_rule.private_fields_should_be_camel_case_with_underscore.symbols  = private_fields                                                                                            
dotnet_naming_rule.private_fields_should_be_camel_case_with_underscore.style    = camel_case_underscore_style                                                                               
                                                                                                                                                                                            
dotnet_naming_symbols.private_fields.applicable_kinds           = field                                                                                                                     
dotnet_naming_symbols.private_fields.applicable_accessibilities = private                                                                                                                   
                                                                                                                                                                                            
dotnet_naming_style.camel_case_underscore_style.required_prefix = _                                                                                                                         
dotnet_naming_style.camel_case_underscore_style.capitalization  = camel_case
                                                                                                                                                                                            
# ============================================================
# JSON / YAML / Markdown / config                                                                                                                                                           
# 2-space indent is the web/JS convention. Mixing 4-space C# with 2-space JSON
# is the standard split in .NET repos.                                                                                                                                                      
# ============================================================                                                                                                                              
[*.{json,yml,yaml}]                                                                                                                                                                         
indent_size = 2                                                                                                                                                                             
                
[*.{js,jsx,ts,tsx}]
indent_size = 2
                                                                                                                                                                                            
[*.{html,css,scss}]
indent_size = 2                                                                                                                                                                             
                
[*.md]
indent_size              = 2
trim_trailing_whitespace = false   # Trailing 2 spaces in Markdown = hard line break. Don't strip them.
                                                                                                                                                                                            
# ============================================================                                                                                                                              
# Project & solution files                                                                                                                                                                  
# Visual Studio writes these with CRLF + tabs. Don't fight VS — it'll rewrite them anyway.                                                                                                  
# ============================================================                                                                                                                              
[*.{csproj,vbproj,proj,projitems,shproj,sln,props,targets}]
indent_style = space                                                                                                                                                                        
indent_size  = 2
end_of_line  = crlf   # VS persists CRLF here regardless of what we say; explicit is honest.   